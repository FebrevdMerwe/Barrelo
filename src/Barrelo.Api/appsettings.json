{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "BarreloDb": "Data Source=barrelo.db"
  },
  "Plugins": {
    "Directory": "plugins"
  },
  "Detection": {
    "Mode": "Simulator",
    "Simulator": {
      "Url": "ws://localhost:5250/stream"
    }
  }
}
